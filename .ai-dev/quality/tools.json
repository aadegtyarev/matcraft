{
  "tools": [
    {
      "id": "rustfmt",
      "checks": "Code formatting (rustfmt)",
      "run": "cargo fmt -- --check",
      "beat": "build",
      "init": "rustup component add rustfmt"
    },
    {
      "id": "build",
      "checks": "Build all targets (check compilation)",
      "run": "cargo build --all-targets",
      "beat": "build",
      "init": ""
    },
    {
      "id": "clippy",
      "checks": "Clippy lint checks with deny warnings",
      "run": "cargo clippy -- -D warnings",
      "beat": "build",
      "init": "rustup component add clippy"
    },
    {
      "id": "test",
      "checks": "Run all tests",
      "run": "cargo test",
      "beat": "build",
      "init": ""
    },
    {
      "id": "doc",
      "checks": "Check documentation builds without warnings",
      "run": "cargo doc --no-deps --document-private-items",
      "beat": "build",
      "init": ""
    },
    {
      "id": "audit",
      "checks": "Security audit of dependencies (known vulnerabilities)",
      "run": "cargo audit",
      "beat": "build",
      "init": "cargo install cargo-audit"
    }
  ]
}
